# Copy to bot/.env and fill in (do not commit .env). Loaded at process start with
# github.com/joho/godotenv (OS environment wins over the file for the same key).
# See: specs/002-env-file-config/quickstart.md
TELEGRAM_BOT_TOKEN=
# Required: PostgreSQL connection (local: run `docker compose up -d` from repo root, then e.g.):
# postgres://lifesound:lifesound@localhost:5432/lifesound?sslmode=disable
DATABASE_URL=
# Optional: run Goose migrations up at startup (useful in dev; prod may use a job)
AUTO_MIGRATE=true
# Optional: absolute or cwd-relative path to SQL migrations (default: migrations for local dev from bot/)
# MIGRATIONS_PATH=
# Optional: MusicBrainz contact User-Agent; otherwise a default app string is used
# MUSICBRAINZ_USER_AGENT=
# Optional: Last.fm album search (orchestrator skips when unset)
# LASTFM_API_KEY=
# Optional: DEBUG, INFO (default), WARN, ERROR
LOG_LEVEL=INFO
