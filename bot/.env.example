# Copy to bot/.env and fill in (do not commit .env). Loaded at process start with
# github.com/joho/godotenv (OS environment wins over the file for the same key).
# See: specs/002-env-file-config/quickstart.md
TELEGRAM_BOT_TOKEN=
# Required: PostgreSQL connection (local: run `docker compose up -d` from repo root, then e.g.):
# postgres://lifesound:lifesound@localhost:5432/lifesound?sslmode=disable
DATABASE_URL=
# Optional: run Goose migrations up at startup (useful in dev; prod may use a job)
AUTO_MIGRATE=true
# Optional: absolute or cwd-relative path to SQL migrations (default: migrations for local dev from bot/)
# MIGRATIONS_PATH=
# Optional: MusicBrainz contact User-Agent; otherwise a default app string is used
# MUSICBRAINZ_USER_AGENT=
# Optional: Last.fm album search (disabled via LST_METADATA_ENABLE_LASTFM=false or when unset key)
# LASTFM_API_KEY=
# Spotify Web API (first in metadata chain; optional — falls through to iTunes if missing)
# LST_METADATA_ENABLE_SPOTIFY=true
# LST_METADATA_ENABLE_ITUNES=true
# LST_METADATA_ENABLE_LASTFM=true
# LST_METADATA_ENABLE_MUSICBRAINZ=true
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# See: specs/003-save-album-command/quickstart.md
# Daily album recommendations (004): unset LST_DAILY_RECOMMENDATIONS_ENABLE → on (opt-out)
# LST_DAILY_RECOMMENDATIONS_ENABLE=true
# LST_DAILY_RECOMMENDATIONS_TZ=UTC
# LST_DAILY_RECOMMENDATIONS_CRON=0 6 * * *
# See: specs/004-daily-album-recommendations/contracts/feature-flags.md
# Optional: DEBUG, INFO (default), WARN, ERROR
LOG_LEVEL=INFO
