# Required
TELEGRAM_BOT_TOKEN=

# PostgreSQL (local dev: docker compose up -d from repo root)
DATABASE_URL=postgres://lifesoundtrack:lifesoundtrack@localhost:5432/lifesoundtrack?sslmode=disable

# polling | webhook
TRANSPORT=polling

# --- Webhook only ---
# LISTEN_ADDR=:8080
# WEBHOOK_URL=https://example.com
# WEBHOOK_PATH=/telegram/webhook
# Optional; when set, must match Telegram setWebhook secret_token header
# WEBHOOK_SECRET_TOKEN=

# Daily album recommendation (UTC)
# DAILY_RECOMMENDATION_ENABLED=true
# DAILY_RECOMMENDATION_HOUR_UTC=9
